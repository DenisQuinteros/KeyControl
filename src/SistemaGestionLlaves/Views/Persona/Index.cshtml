@model IEnumerable<SistemaGestionLlaves.Models.Persona>

@{
    ViewData["Title"] = "Personas";
}

<div class="container-fluid">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-people me-2"></i>Gestión de Personas
            </h5>
            <a asp-action="Create" class="btn btn-primary px-4">
                <i class="bi bi-plus-lg me-1"></i> Nueva Persona
            </a>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <form method="get" class="d-flex gap-2">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control border-start-0 ps-0" placeholder="Buscar por nombre, apellido o CI..." />
                            <button type="submit" class="btn btn-outline-primary">Buscar</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre Completo</th>
                            <th>CI</th>
                            <th>Correo</th>
                            <th>Celular</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end" style="width: 150px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@item.NombreCompleto</td>
                                <td>@item.Ci</td>
                                <td>@item.Correo</td>
                                <td>@item.Celular</td>
                                <td class="text-center">
                                    @if (item.Estado == "A")
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle">Inactivo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.IdPersona" class="btn btn-outline-info btn-sm border-0" title="Ver detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.IdPersona" class="btn btn-outline-warning btn-sm border-0" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IdPersona" class="btn btn-outline-danger btn-sm border-0" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-4">
                <partial name="_Paginador" />
            </div>
        </div>
    </div>
</div>