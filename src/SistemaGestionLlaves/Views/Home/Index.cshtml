@{
    ViewData["Title"] = "Dashboard";
}

<div class="row g-4 mb-4">
    <!-- 4 KPI Cards -->
    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3">
            <h6 class="text-muted">Total Llaves</h6>
            <h2 class="fw-bold mb-0 text-primary" id="kpiTotalLlaves">...</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3">
            <h6 class="text-muted">Llaves Disponibles</h6>
            <h2 class="fw-bold mb-0 text-success" id="kpiLlavesDisponibles">...</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3">
            <h6 class="text-muted">Llaves Prestadas</h6>
            <h2 class="fw-bold mb-0 text-warning" id="kpiLlavesPrestadas">...</h2>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center p-3">
            <h6 class="text-muted">Préstamos Activos</h6>
            <h2 class="fw-bold mb-0 text-info" id="kpiPrestamosActivos">...</h2>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Gráfica de línea (7 días) -->
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">Préstamos de la Semana</h5>
            </div>
            <div class="card-body">
                <canvas id="prestamosChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Gráfica donut de estado de llaves -->
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">Estado de Llaves</h5>
            </div>
            <div class="card-body d-flex justify-content-center align-items-center">
                <canvas id="estadoLlavesChart" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Tabla Actividad Reciente -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">Actividad Reciente</h5>
                <a asp-controller="Prestamos" asp-action="Index" class="text-decoration-none text-muted small">Ver todo <i class="bi bi-chevron-right"></i></a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Usuario / Persona</th>
                                <th>Llave / Ambiente</th>
                                <th>Fecha y Hora</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody id="actividadRecienteTable">
                            <tr><td colspan="4" class="text-center text-muted">Cargando actividad...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Fetch KPIs
            fetch('/api/dashboard/kpis')
                .then(r => r.json())
                .then(data => {
                    document.getElementById('kpiTotalLlaves').innerText = data.totalLlaves;
                    document.getElementById('kpiLlavesDisponibles').innerText = data.llavesDisponibles;
                    document.getElementById('kpiLlavesPrestadas').innerText = data.llavesPrestadas;
                    document.getElementById('kpiPrestamosActivos').innerText = data.prestamosActivos;
                })
                .catch(err => console.error("Error cargando KPIs", err));

            // 2. Fetch Préstamos Semana (Line Chart)
            fetch('/api/dashboard/prestamos-semana')
                .then(r => r.json())
                .then(data => {
                    const ctx = document.getElementById('prestamosChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.labels,
                            datasets: [{
                                label: 'Préstamos Registrados',
                                data: data.valores,
                                borderColor: '#0369a1',
                                backgroundColor: 'rgba(3, 105, 161, 0.1)',
                                tension: 0.3,
                                fill: true
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                y: { beginAtZero: true, ticks: { precision: 0 } }
                            }
                        }
                    });
                })
                .catch(err => console.error("Error cargando gráfica de línea", err));

            // 3. Fetch Estado de Llaves (Donut Chart)
            fetch('/api/dashboard/estado-llaves')
                .then(r => r.json())
                .then(data => {
                    const ctx = document.getElementById('estadoLlavesChart').getContext('2d');
                    new Chart(ctx, {
                        type: 'doughnut',
                        data: {
                            labels: data.labels,
                            datasets: [{
                                data: data.valores,
                                backgroundColor: data.colores,
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom' }
                            }
                        }
                    });
                })
                .catch(err => console.error("Error cargando gráfica donut", err));

            // 4. Fetch Actividad Reciente
            fetch('/api/dashboard/actividad-reciente?limit=8')
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('actividadRecienteTable');
                    tbody.innerHTML = '';
                    if (!data.data || data.data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">No hay actividad reciente</td></tr>';
                        return;
                    }

                    data.data.forEach(item => {
                        let personaName = item.persona || "Desconocido";
                        let llaveCodigo = item.llave || "-";
                        let ambienteNom = item.ambiente || "-";
                        let fechaStr = new Date(item.fecha).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' });
                        let estadoTexto = item.estadoTexto || item.estado;

                        // Determinar estilo base al estado
                        let badgeClass = "bg-secondary";
                        let iconClass = "bi-circle";
                        let textClass = "text-secondary";

                        if (estadoTexto === "Prestado") { 
                            badgeClass = "bg-warning text-dark"; textClass = "text-warning"; iconClass = "bi-key"; 
                        } else if (estadoTexto === "Devuelto") { 
                            badgeClass = "bg-success"; textClass = "text-success"; iconClass = "bi-check-circle"; 
                        } else if (estadoTexto === "Vencido") { 
                            badgeClass = "bg-danger"; textClass = "text-danger"; iconClass = "bi-exclamation-circle"; 
                        } else if (estadoTexto === "Cancelado") {
                            badgeClass = "bg-secondary text-white"; textClass = "text-secondary"; iconClass = "bi-x-circle";
                        }

                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-light rounded-3 p-2 ${textClass}">
                                        <i class="bi bi-person-circle fs-5"></i>
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-semibold">${personaName}</h6>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <h6 class="mb-0 fw-semibold">${llaveCodigo}</h6>
                                <small class="text-muted">${ambienteNom}</small>
                            </td>
                            <td>
                                <span>${fechaStr}</span>
                            </td>
                            <td>
                                <span class="badge ${badgeClass}"><i class="bi ${iconClass} me-1"></i> ${estadoTexto}</span>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                })
                .catch(err => {
                    console.error("Error cargando actividad reciente", err);
                    document.getElementById('actividadRecienteTable').innerHTML = '<tr><td colspan="4" class="text-center text-danger">Error al cargar actividad</td></tr>';
                });
        });
    </script>
}
