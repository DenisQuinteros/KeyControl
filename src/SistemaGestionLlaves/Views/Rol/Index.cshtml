@model IEnumerable<SistemaGestionLlaves.Models.Rol>
@{
    ViewData["Title"] = "Roles";
}

<div class="container-fluid">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-shield-lock me-2"></i>Gestión de Roles
            </h5>
            <div class="d-flex gap-2">
                <a asp-controller="Usuarios" asp-action="Index" class="btn btn-outline-secondary px-3">
                    <i class="bi bi-people me-1"></i> Volver a Usuarios
                </a>
                <a asp-action="Create" class="btn btn-primary px-3">
                    <i class="bi bi-plus-lg me-1"></i> Nuevo Rol
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5 border rounded-4 bg-light">
                    <i class="bi bi-shield-x text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted">No hay roles registrados.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre del Rol</th>
                                <th>Descripción</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-primary-subtle rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-shield-check text-primary" style="font-size: 1.2rem;"></i>
                                            </div>
                                            <span class="fw-bold text-dark">@item.NombreRol</span>
                                        </div>
                                    </td>
                                    <td class="text-muted">
                                        @(string.IsNullOrWhiteSpace(item.Descripcion) ? "-" : item.Descripcion)
                                    </td>
                                    <td class="text-center">
                                        @if (item.Estado == "A")
                                        {
                                            <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                <i class="bi bi-check-circle me-1"></i>Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                                <i class="bi bi-x-circle me-1"></i>Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Details" asp-route-id="@item.IdRol" class="btn btn-primary btn-sm" title="Ver detalles">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.IdRol" class="btn btn-warning btn-sm" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.IdRol" class="btn btn-danger btn-sm" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="mt-4">
                <partial name="_Paginador" />
            </div>
        </div>
    </div>
</div>
