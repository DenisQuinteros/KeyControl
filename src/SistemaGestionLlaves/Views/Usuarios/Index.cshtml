@model IEnumerable<SistemaGestionLlaves.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="container-fluid">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center flex-wrap gap-3">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-people me-2"></i>Gestión de Usuarios
            </h5>
            <div class="d-flex gap-2">
                <a asp-controller="Rol" asp-action="Index" class="btn btn-outline-primary px-3">
                    <i class="bi bi-shield-lock me-1"></i> Gestionar Roles
                </a>
                <a asp-action="Create" class="btn btn-primary px-3">
                    <i class="bi bi-plus-lg me-1"></i> Nuevo Usuario
                </a>
            </div>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5 border rounded-4 bg-light">
                    <i class="bi bi-person-x text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted">No hay usuarios registrados.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Usuario</th>
                                <th>Persona</th>
                                <th class="text-center">Rol</th>
                                <th class="text-center">Estado</th>
                                <th class="text-end" style="width: 150px;">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-primary-subtle rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-person-badge text-primary" style="font-size: 1.2rem;"></i>
                                            </div>
                                            <span class="fw-bold text-dark">@item.NombreUsuario</span>
                                        </div>
                                    </td>
                                    <td class="text-muted">@item.Persona?.NombreCompleto</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle px-3">
                                            @item.Rol?.NombreRol
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var (bgClass, icon, label) = item.Estado switch
                                            {
                                                "A" => ("success", "check-circle", "Activo"),
                                                "B" => ("warning", "lock", "Bloqueado"),
                                                _ => ("secondary", "x-circle", "Inactivo")
                                            };
                                        }
                                        <span class="badge rounded-pill bg-@bgClass-subtle text-@bgClass border border-@bgClass-subtle px-3 py-2">
                                            <i class="bi bi-@icon me-1"></i>@label
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Details" asp-route-id="@item.IdUsuario" class="btn btn-outline-info btn-sm border-0" title="Ver detalles">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.IdUsuario" class="btn btn-outline-warning btn-sm border-0" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.IdUsuario" class="btn btn-outline-danger btn-sm border-0" title="Eliminar">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="mt-4">
                <partial name="_Paginador" />
            </div>
        </div>
    </div>
</div>
