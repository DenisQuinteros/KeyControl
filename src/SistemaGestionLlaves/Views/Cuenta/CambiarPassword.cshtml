@model SistemaGestionLlaves.Models.ViewModels.CambiarPasswordViewModel

@{
    ViewData["Title"] = "Cambiar Contraseña";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-lg">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0"><i class="bi bi-key-fill text-warning me-2"></i>Cambiar Contraseña</h4>
            </div>
            <div class="card-body p-4">
                @if (TempData["MensajeExito"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["MensajeExito"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="CambiarPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-4 form-floating">
                        <input asp-for="PasswordActual" class="form-control" placeholder="Contraseña Actual" />
                        <label asp-for="PasswordActual"></label>
                        <span asp-validation-for="PasswordActual" class="text-danger small"></span>
                    </div>

                    <div class="mb-4 form-floating">
                        <input asp-for="NuevaPassword" class="form-control" placeholder="Nueva Contraseña" />
                        <label asp-for="NuevaPassword"></label>
                        <span asp-validation-for="NuevaPassword" class="text-danger small"></span>
                        <div class="form-text small text-muted">Mínimo 8 caracteres, al menos una letra y un número.</div>
                    </div>

                    <div class="mb-4 form-floating">
                        <input asp-for="ConfirmarPassword" class="form-control" placeholder="Confirmar Contraseña" />
                        <label asp-for="ConfirmarPassword"></label>
                        <span asp-validation-for="ConfirmarPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary py-2 text-uppercase fw-bold">
                            Cambiar Contraseña
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary-secondary py-2">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
