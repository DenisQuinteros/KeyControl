@model IEnumerable<SistemaGestionLlaves.Models.Llave>
@{
    ViewData["Title"] = "KeyControler";
}

<div class="container-fluid">
    <!-- Alertas -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="border-radius: 12px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mb-4" role="alert" style="border-radius: 12px;">
            <i class="bi bi-exclamation-circle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-key me-2"></i>KeyControler
            </h5>
            <a asp-action="Create" class="btn btn-primary px-4">
                <i class="bi bi-plus-lg me-1"></i> Nueva Llave
            </a>
        </div>
        <div class="card-body">
            <!-- Filtros -->
            <form asp-action="Index" method="get" class="row g-3 mb-4 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Búsqueda</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="busqueda" value="@ViewData["busqueda"]" class="form-control" placeholder="Código o nombre..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Ambiente</label>
                    <select name="idAmbiente" class="form-select bg-light" asp-items="ViewBag.Ambientes">
                        <option value="">Todos los ambientes</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted text-uppercase">Estado</label>
                    <select name="estado" class="form-select bg-light">
                        <option value="">Todos</option>
                        <option value="D" selected="@(ViewData["estado"]?.ToString() == "D")">Disponible</option>
                        <option value="P" selected="@(ViewData["estado"]?.ToString() == "P")">Prestada</option>
                        <option value="R" selected="@(ViewData["estado"]?.ToString() == "R")">Reservada</option>
                        <option value="I" selected="@(ViewData["estado"]?.ToString() == "I")">Inactiva</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-1"></i>Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-x-circle me-1"></i>Limpiar
                    </a>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="text-center py-5 border rounded-4 bg-light">
                    <i class="bi bi-key text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted">No se encontraron llaves con los criterios aplicados.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Código / Tipo</th>
                                <th>Ambiente</th>
                                <th class="text-center">Copias</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var llave in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-primary-subtle rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-key@(llave.EsMaestra ? "-fill text-warning" : " text-primary")" style="font-size: 1.2rem;"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@llave.Codigo</div>
                                                <span class="badge @(llave.EsMaestra ? "bg-warning-subtle text-warning border border-warning-subtle" : "bg-light text-muted border")" style="font-size: 0.65rem;">
                                                    @(llave.EsMaestra ? "MAESTRA" : "ESTÁNDAR")
                                                </span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="text-dark">@llave.Ambiente?.Nombre</div>
                                        <small class="text-muted">@llave.Ambiente?.Codigo</small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-light text-dark border px-2">@llave.NumCopias</span>
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var (bgClass, icon, label) = llave.Estado switch
                                            {
                                                "D" => ("success", "check-circle", "Disponible"),
                                                "P" => ("warning", "arrow-left-right", "Prestada"),
                                                "R" => ("info", "calendar-check", "Reservada"),
                                                _   => ("secondary", "x-circle", "Inactiva")
                                            };
                                        }
                                        <span class="badge rounded-pill bg-@bgClass-subtle text-@bgClass border border-@bgClass-subtle px-3 py-2">
                                            <i class="bi bi-@icon me-1"></i>@label
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Details" asp-route-id="@llave.IdLlave" class="btn btn-primary btn-sm" title="Ver detalles">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            @if (llave.Estado != "P")
                                            {
                                                <a asp-action="Edit" asp-route-id="@llave.IdLlave" class="btn btn-warning btn-sm" title="Editar">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-action="CambiarEstado" asp-route-id="@llave.IdLlave" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" title="@(llave.Estado == "I" ? "Activar" : "Inactivar")"
                                                            class="btn btn-outline-@(llave.Estado == "I" ? "success" : "danger") btn-sm border-0"
                                                            onclick="return confirm('¿Confirmar cambio de estado?')">
                                                        <i class="bi bi-@(llave.Estado == "I" ? "toggle-on" : "toggle-off")"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="mt-4">
                <partial name="_Paginador" />
            </div>
        </div>
    </div>
</div>
