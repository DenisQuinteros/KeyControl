@model IEnumerable<SistemaGestionLlaves.Models.Ambiente>
@{
    ViewData["Title"] = "Ambientes";
}

<div class="container-fluid">
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-door-open me-2"></i>Gestión de Ambientes
            </h5>
            <a asp-action="Create" class="btn btn-primary px-4">
                <i class="bi bi-plus-lg me-1"></i> Nuevo Ambiente
            </a>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-6">
                    <form asp-action="Index" method="get" class="d-flex gap-2">
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0">
                                <i class="bi bi-search text-muted"></i>
                            </span>
                            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control border-start-0 ps-0" placeholder="Buscar ambiente o código..." />
                            <button type="submit" class="btn btn-outline-primary">Buscar</button>
                        </div>
                    </form>
                </div>
            </div>
            @if (!Model.Any())
            {
                <div class="text-center py-5 border rounded-4 bg-light">
                    <i class="bi bi-door-closed text-muted" style="font-size: 3rem;"></i>
                    <p class="mt-3 text-muted">No hay ambientes registrados.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre / Código</th>
                                <th>Tipo</th>
                                <th>Ubicación</th>
                                <th class="text-center">Llaves</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-primary-subtle rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-building text-primary" style="font-size: 1.2rem;"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.Nombre</div>
                                                <small class="text-muted">@item.Codigo</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-info-subtle text-info border border-info-subtle px-3">
                                            @item.TipoAmbiente?.NombreTipo
                                        </span>
                                    </td>
                                    <td class="text-muted">@item.Ubicacion</td>
                                    <td class="text-center">
                                        <a asp-controller="LlavesView" asp-action="Index" asp-route-idAmbiente="@item.IdAmbiente" 
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="bi bi-key me-1"></i>@item.Llaves.Count
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        @if (item.Estado == "A")
                                        {
                                            <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                                <i class="bi bi-check-circle me-1"></i>Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                                <i class="bi bi-x-circle me-1"></i>Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Details" asp-route-id="@item.IdAmbiente" class="btn btn-primary btn-sm" title="Ver detalles">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.IdAmbiente" class="btn btn-warning btn-sm" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="mt-4">
                <partial name="_Paginador" />
            </div>
        </div>
    </div>
</div>
